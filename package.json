{
  "name": "jarvis-print-manage",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:free-port": "node scripts/dev-free-port.mjs",
    "dev:web": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "dev": "npm run dev:free-port && concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "start": "electron .",
    "build:web": "vite build",
    "build": "npm run build:web && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "@icon-park/vue-next": "^1.4.2",
    "electron-updater": "^6.8.9",
    "element-plus": "^2.13.6",
    "pinia": "^3.0.4",
    "socket.io": "^4.8.3",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "vite": "^8.1.4",
    "vite-plugin-vue-devtools": "^8.1.5",
    "wait-on": "^9.0.4"
  },
  "overrides": {
    "vite-plugin-inspect": "^11.4.1",
    "vite-dev-rpc": "^2.0.0",
    "vite-hot-client": "^2.2.0"
  },
  "build": {
    "appId": "cc.eu.iiot.hs.tool",
    "productName": "打印机助手",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!electron/resource{,/**}",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "electron/resource",
        "to": "."
      }
    ],
    "directories": {
      "output": "release"
    },
    "protocols": [
      {
        "name": "打印机助手协议",
        "schemes": [
          "hstools"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "jarvis-workbench",
        "repo": "jarvis-print-manage"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "asar": true,
    "asarUnpack": [
      "electron/**/*.mjs"
    ]
  }
}
